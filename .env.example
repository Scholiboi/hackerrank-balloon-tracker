# ── HackerRank Poller (built into the backend) ───────────────────────────────
# The slug from the contest URL: hackerrank.com/contests/<CONTEST_NAME>
# Leave blank to disable polling (backend still works without it)
HACKERRANK_CONTEST_NAME=

# Auth cookies as a JSON object (copy from browser DevTools → Network → Cookies)
HACKERRANK_COOKIES={}

# Optional extra request headers as a JSON object
HACKERRANK_HEADERS={}

# How often (seconds) to poll HackerRank
POLL_INTERVAL=10

# ── Backend ───────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=changeme

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-string

JWT_EXPIRY_HOURS=8

# Allowed CORS origin — set to your public domain in production
FRONTEND_ORIGIN=https://cuc.scholiboi.dev

# SQLite path inside the backend container (leave as-is for Docker)
DATABASE_URL=sqlite:///./data/contest.db
